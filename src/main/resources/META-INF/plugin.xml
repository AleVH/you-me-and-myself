<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>com.youmeandmyself.ai</id>
    <name>YouMeAndMyself Assistant</name>
    <version>0.1.0</version>
    <vendor email="dev@example.com">YouMeAndMyself</vendor>
    <description>Generic multi-provider AI scaffold with connectivity test.</description>

    <!--
        JetBrains Marketplace paid plugin descriptor.
        Required for any plugin that uses the freemium or paid model.

        - code:            Product identifier in the JetBrains sales system. Must start with P,
                           uppercase, 4-15 chars, no digits or special chars. Changing this after
                           publication is painful — pick carefully.
                           TODO: Confirm "PYMM" availability with JetBrains before first submission.

        - release-date:    Date of the first public release (YYYYMMDD). Affects subscription
                           fallback rights — users who paid before this date get perpetual access
                           to this version.
                           TODO: Set to actual launch date.

        - release-version: Integer version for licensing comparison. Convention: major*10000 +
                           minor*100 + patch (so 1.0.0 = 10000, 1.2.3 = 10203). Must be updated
                           with each release that changes subscription-relevant behavior.
                           TODO: Keep in sync with <version> tag at release time.
    -->
    <!-- DEV: Commented out to skip JetBrains platform license enforcement during development.
         Uncomment before Marketplace submission.
    <product-descriptor code="PYMM"
                        release-date="20260401"
                        release-version="10000"/>
    -->

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="git-integration.xml">Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- ═══ UI ════════════════════════════════════════════════════════ -->

        <!-- Main chat tool window (right sidebar) -->
        <toolWindow id="YMM Chat"
                    factoryClass="com.youmeandmyself.ai.chat.ChatToolWindowFactory"
                    anchor="right"/>

        <!-- ═══ Settings Pages ════════════════════════════════════════════ -->

        <!-- Root settings node under Tools → YMM Assistant -->
        <projectConfigurable instance="com.youmeandmyself.ai.settings.AiProfilesConfigurable"
                             displayName="YMM Assistant"
                             id="com.youmeandmyself.ai.settings"
                             parentId="tools"/>

        <!-- Settings → YMM Assistant → Summary -->
        <projectConfigurable instance="com.youmeandmyself.ai.settings.SummaryConfigurable"
                             displayName="Summary"
                             id="com.youmeandmyself.ai.settings.summary"
                             parentId="com.youmeandmyself.ai.settings"/>

        <!-- Settings → YMM Assistant → General -->
        <projectConfigurable instance="com.youmeandmyself.ai.settings.GeneralConfigurable"
                             displayName="General"
                             id="com.youmeandmyself.ai.settings.general"
                             parentId="com.youmeandmyself.ai.settings"/>

        <!-- ═══ Notifications ═════════════════════════════════════════════ -->

        <notificationGroup id="AI Plugin" displayType="BALLOON" isLogByDefault="true"/>

        <!-- ═══ Application-Level Services (global, not per-project) ═════ -->

        <!--
            Tier provider: single entry point for all tier/feature checks.
            CompositeTierProvider checks custom server first (Company tiers),
            then falls back to JetBrains Marketplace licensing (Individual tiers).
            At launch, custom server returns NONE → effectively delegates to JB.
        -->
        <applicationService
                serviceInterface="com.youmeandmyself.tier.TierProvider"
                serviceImplementation="com.youmeandmyself.tier.CompositeTierProvider"/>

        <!--
            Account service: placeholder for future user identity and org context.
            All methods return null/defaults at launch. Wired here so the package
            has a home and future Company tier code can depend on it.
        -->
        <applicationService
                serviceImplementation="com.youmeandmyself.account.AccountService"/>

        <!-- ═══ Project-Level Services ════════════════════════════════════ -->

        <!-- Core storage: JSONL (source of truth) + SQLite (rebuildable index) -->
        <projectService serviceImplementation="com.youmeandmyself.storage.LocalStorageFacade"/>

        <!-- Runs on project open: initializes storage, rebuilds SQLite from JSONL if needed -->
        <postStartupActivity implementation="com.youmeandmyself.storage.StorageInitializer"/>

        <!-- Summarization: config, cache, pipeline, file-change watcher, structure detection -->
        <projectService serviceImplementation="com.youmeandmyself.summary.config.SummaryConfigService"/>
        <projectService serviceImplementation="com.youmeandmyself.summary.cache.SummaryCache"/>
        <projectService serviceImplementation="com.youmeandmyself.summary.pipeline.SummaryPipeline"/>
        <projectService serviceImplementation="com.youmeandmyself.summary.watcher.VfsSummaryWatcher"/>
        <projectService serviceImplementation="com.youmeandmyself.summary.structure.CodeStructureProviderFactory"/>

        <!-- Library: full-text search and bookmark/collection management -->
        <projectService serviceImplementation="com.youmeandmyself.storage.search.SearchService"/>
        <projectService serviceImplementation="com.youmeandmyself.storage.BookmarkService"/>

        <!-- Chat: conversation lifecycle (create, load, switch, close) -->
        <projectService serviceImplementation="com.youmeandmyself.ai.chat.conversation.ConversationManager"/>

        <!-- ── MetricsService — project-level service ──────────────────────── -->
        <!-- One instance per project. Receives token data from BridgeDispatcher,
             writes MetricsRecord to SQLite, builds UpdateMetricsEvent. -->
        <projectService serviceImplementation="com.youmeandmyself.ai.metrics.MetricsService"/>

        <!-- ── MetricsSettingsState — project-level persistent state ───────── -->
        <!-- Stores metrics user preferences (showMetricsBar, etc.).
             Persisted to ymmMetricsSettings.xml in the project config dir. -->
        <projectService serviceImplementation="com.youmeandmyself.ai.settings.MetricsSettingsState"/>

        <!-- ── MetricsConfigurable — settings UI page ─────────────────────── -->
        <!-- Settings → Tools → YMM Assistant → Metrics
             Nested under the YMM root node (parentId matches the root configurable). -->
        <projectConfigurable
                instance="com.youmeandmyself.ai.settings.MetricsConfigurable"
                displayName="Metrics"
                id="com.youmeandmyself.ai.settings.metrics"
                parentId="com.youmeandmyself.ai.settings"/>

        <!-- Assistant Profile settings: Tools → YMM Assistant → Assistant Profile -->
        <projectConfigurable instance="com.youmeandmyself.ai.settings.AssistantProfileConfigurable"
                             parentId="com.youmeandmyself.ai.settings"
                             id="com.youmeandmyself.ai.settings.assistantProfile"
                             displayName="Assistant Profile"/>

        <!-- ── ContextSettingsState — project-level persistent state ──────── -->
        <!-- Stores context control preferences (contextEnabled, defaultBypassMode).
             Persisted to ymmContextSettings.xml in the project config dir.
             STUB: not yet read by ContextAssembler — per-message bypassMode is the
             only active context control at launch. -->
        <projectService serviceImplementation="com.youmeandmyself.ai.settings.ContextSettingsState"/>

        <!-- Context settings: Tools → YMM Assistant → Context (Block 5) -->
        <projectConfigurable instance="com.youmeandmyself.ai.settings.ContextConfigurable"
                             parentId="com.youmeandmyself.ai.settings"
                             id="com.youmeandmyself.ai.settings.context"
                             displayName="Context"/>

        <!-- ── BudgetChecker — project-level service ───────────────────────── -->
        <!--
            Budget enforcement gate: every AI call checks this before execution.

            At launch (Individual Basic), AlwaysAllowBudgetChecker approves everything.
            Post-launch (Pro/Company tiers), swap serviceImplementation to the real
            enforcement class — all consumers code against the BudgetChecker interface,
            so zero caller changes needed.

            Registered with serviceInterface so callers can request BudgetChecker
            (the interface) and get whatever implementation is active.
        -->
        <projectService
                serviceInterface="com.youmeandmyself.budget.BudgetChecker"
                serviceImplementation="com.youmeandmyself.budget.AlwaysAllowBudgetChecker"/>

        <!-- ── AssistantProfileService — project-level service ─────────────── -->
        <!--
            Manages the user's assistant profile: YAML parsing, validation,
            summarization, system prompt injection, file watching.

            Project-level because it needs access to the project's message bus
            for VFS file watching and to LocalStorageFacade for SQLite access.
            The profile itself is global (not per-project), but the service
            lifecycle is tied to the project.

            Initialized lazily on first access (typically on first chat message
            or when the settings page is opened).
        -->
        <projectService
                serviceImplementation="com.youmeandmyself.profile.AssistantProfileService"/>
    </extensions>

    <actions>

        <!-- Tools → AI submenu -->
        <group id="com.youmeandmyself.ai.toolsGroup"
               text="AI"
               popup="true"
               description="AI tools">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </group>

        <!-- Keyboard shortcut to open the chat panel -->
        <action id="com.youmeandmyself.ai.actions.OpenChatToolWindow"
                class="com.youmeandmyself.ai.actions.OpenChatToolWindowAction"
                text="Open YMM Assistant">
            <add-to-group group-id="com.youmeandmyself.ai.toolsGroup" anchor="last"/>
            <keyboard-shortcut first-keystroke="ctrl alt Y" keymap="$default"/>
            <keyboard-shortcut first-keystroke="meta alt Y" keymap="Mac OS X"/>
        </action>

    </actions>
</idea-plugin>